# 이진 탐색 알고리즘
# 순차 탐색: 리스트 안에 존재하는 특정한 데이터를 찾기 위해 앞에서부터 데이터를 하나씩 확인
# 이진 탐색: 정렬된 리스트에서 탐색 범위를 절반씩 좁혀가며 테이터 탐색
# 시작점, 끝점, 중간점을 이용하여 탐색 범위를 설정

# step 1: 시작점, 끝점, 중간점 지정, 인덱스
# 중간점은 소수점 이하 제거해서 인덱스 결정
# step 2: 중간점을 기준으로 중간점에 해당하는 값과 찾고 싶은 값 비교
# 반복하면 중간점이 타겟이 되면 종료

# 재귀적 구현
# 탐색 배열, 찾고자 하는 데이터, 탐색 범위
def binary_search(array, target, start, end):
    # 재귀적 구현이기 때문에 시작 인덱스가 끝 인덱스 보다 커지면 찾고자 하는 값이 없는 것!
    if start > end: # 탐색하고자 하는 데이터가 범위에 없을 경우
        return None 
    mid = (start+end)// 2 # 몫으로 중간점 
    if array[mid] == target: # 찾은 경우 중간점 인덱스 반환
        return mid
    elif array[mid]> target: # 중간점 값보다 찾고자 하는 값이 작을 경우
        return binary_search(array, target, start, mid-1)
    else: # 중간점 값보다 찾고자 하는 값이 큰 경우
        return binary_search(array, target, mid+1, end)
        
# n: 원소의 개수, target: 찾고자 하는 값 입력 받기
n, target = list(map(int, input().split()))
# 전체 배열 입력 받기
array = list(map(int, input().split()))

result = binary_search(array, target, 0, n-1)
if result == None:
    print('원소가 존재하지 않습니다.')
else:
    print(result+1) # 인덱스는 0부터 시작하기 때문에 출력되는 값은 인덱스+1로 몇 번째 원소인지
    
