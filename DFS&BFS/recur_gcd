# 최대공약수 계산(유클리드 호제법)
# 두 개의 자연수에 대한 최대공약수를 구하는 대표적인 즈고리즘

# 유클리드 호제법
# 두 자연수 a,b에여대하여 (a>b) a를 b로 나눈 나머지를 r 
# a,b의 최대공약수는 b와 r의 최대공약수와 같다

# gcd(192, 162) # gcd 는 최대공약수를 의미
# 같은 과정을 반복해서 재귀함수로 작성

def gcd(a,b):
    if a % b ==0 :
        return b
    else :
        return gcd(b,a%b) 
        # b와 나머지로 
print(gcd(192,162))


