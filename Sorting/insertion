# 삽입 정렬
# 처리되지 않은 데이터를 하나씩 골라 적절한 위치에 삽입
# 선택 정렬에 비해 구현 난이도는 높지만, 일반적으로 더 효율적으로 동작

# 첫번째 데이터는 그 자체로 정렬 되어 있다고 판단, 두번째 데이터가 왼쪽 혹은 오른쪽으로 들어갈지 판단
# 반복

array = [7,5,9,0,3,1,6,2,4,8]
# 두번째 원소부터 왼쪽으로 이동해 나가면서 위치를 바꿔줌
for i in range(1,len(array)):
  for j in range(i,0,-1): # i부터 1까지 1씩 감소하며 반복
    if array[j] < array[j-1]:
      array[j], array[j-1] = array[j-1] , array[j] # 스왑
    else:
      break
print(array)
