# 두 배열의 원소 교체 예제 

# 문제:
# 두 개의 배열 a,b를 가지고 있으며 n개의 원소로 구성, 모두 자연ㅜ
# 최대 k번의 바꿔치기 연산 가능
# 최종 목표는 배열 a의 모든 원소의 합이 최대가 되도록

# 입력:
# n k 
# 배열 a (공백 구분)
# 배열 b (공백 구분)

# 핵심: 
# 매번 배열 a에서 가장 작은 원소를 골라서 배열 b에서 가장 큰 원소와 교체
# 배열 a에 대하여 오름차순, b는 내림차순 정렬
# 두 원소를 첫번째 인덱스부터 확인하면서 a 원소가 b보다 작을때만 교체 수행

n, k = map(int, input().split())

a = list(map(int, input().split()))
b = list(map(int, input().split()))

a = a.sort()
b = b.sort(reverse=True)

for i in range(k):
    if a[i] < b[i]:
        a[i], b[i] = b[i], a[i]
    else:
        break
        
print(sum(a))

